),
label = "View Exam Scores"
)
)
)
sorting_dropdown <- list(
type = "dropdown",
direction = "down",
y = 1.25, x = 1,
xanchor = "right", yanchor = "top",
showactive = TRUE,
buttons = list(
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_study_high)), label = "Sort: Study (High to Low)"),
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_study_low)), label = "Sort: Study (Low to High)"),
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_sleep_high)), label = "Sort: Sleep (High to Low)"),
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_sleep_low)), label = "Sort: Sleep (Low to High)"),
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_score_high)), label = "Sort: Score (High to Low)"),
list(method = "relayout", args = list(list("xaxis.categoryorder" = "array", "xaxis.categoryarray" = sort_score_low)), label = "Sort: Score (Low to High)")
)
)
student_plot <- plot_ly(profile_stats, x = ~profile_name)
student_plot <- student_plot %>%
add_bars(
y = ~study_hrs,
name = "Study Hours",
marker = list(color = "#232D4B"),
hovertemplate = "<b>%{x}</b><br>Study: %{y} hrs<extra></extra>",
visible = TRUE
) %>%
add_bars(
y = ~sleep_hrs,
name = "Sleep Hours",
marker = list(color = "#E57200"),
hovertemplate = "<b>%{x}</b><br>Sleep: %{y} hrs<extra></extra>",
visible = TRUE
) %>%
add_bars(
y = ~exam_score,
name = "Exam Score",
marker = list(color = "#5C7F92"),
hovertemplate = "<b>%{x}</b><br>Exam Score: %{y}<extra></extra>",
visible = FALSE
)
student_plot <- student_plot %>% layout(
title = list(text = "<b>Time Allocation & Exam Performance by Lifestyle</b>", font = list(size = 18, color = "#232D4B"), y = 0.98),
margin = list(t = 140),
xaxis = list(title = "", tickangle = 0, tickfont = list(size = 12), categoryorder = "array", categoryarray = sort_study_high),
yaxis = list(title = "Average Hours", gridcolor = "#e5e5e5"),
barmode = 'group',
paper_bgcolor = "white",
plot_bgcolor = "white",
annotations = list(baseline_note),
legend = list(orientation = "h", x = 0.5, xanchor = "center", y = -0.15),
updatemenus = list(metric_toggle_buttons, sorting_dropdown)
)
student_plot
library(ggplot2)
library(plotly)
library(scales)
library(shiny)
library(dplyr)
library(readr)
df <- read.csv("StudentPerformanceFactors.csv")
df <- df %>%
rename(
HoursStudied = `Hours Studied`,
ExamScore = `Exam Score`,
Attendance = Attendance
)
df <- df %>%
rename(
Hours_Studied = `Hours Studied`,
Exam_Score = `Exam Score`,
Attendance = Attendance
)
df <- df %>%
rename(
HoursStudied = `Hours_Studied`,
ExamScore = `Exam_Score`,
Attendance = Attendance
)
ui <- fluidPage(
titlePanel("Exam Score vs Hours Studied"),
sidebarLayout(
sidebarPanel(
h4("Filters"),
sliderInput(
"hours_range",
"Hours Studied range:",
min = floor(min(df$HoursStudied, na.rm = TRUE)),
max = ceiling(max(df$HoursStudied, na.rm = TRUE)),
value = c(
floor(min(df$HoursStudied, na.rm = TRUE)),
ceiling(max(df$HoursStudied, na.rm = TRUE))
)
),
sliderInput(
"score_range",
"Exam Score range:",
min = floor(min(df$ExamScore, na.rm = TRUE)),
max = ceiling(max(df$ExamScore, na.rm = TRUE)),
value = c(
floor(min(df$ExamScore, na.rm = TRUE)),
ceiling(max(df$ExamScore, na.rm = TRUE))
)
),
sliderInput(
"attendance_range",
"Attendance range:",
min = floor(min(df$Attendance, na.rm = TRUE)),
max = ceiling(max(df$Attendance, na.rm = TRUE)),
value = c(
floor(min(df$Attendance, na.rm = TRUE)),
ceiling(max(df$Attendance, na.rm = TRUE))
)
),
checkboxInput("remove_outliers", "Filter out outliers", value = TRUE),
helpText("Zoom by dragging on the plot. Double-click to reset.")
),
mainPanel(
plotlyOutput("scatter_plot", height = "650px"),
br(),
h4("Clicked point details"),
verbatimTextOutput("point_info")
)
)
)
server <- function(input, output, session) {
filtered_data <- reactive({
data <- df %>%
filter(
HoursStudied >= input$hours_range[1],
HoursStudied <= input$hours_range[2],
ExamScore >= input$score_range[1],
ExamScore <= input$score_range[2],
Attendance >= input$attendance_range[1],
Attendance <= input$attendance_range[2]
)
if (input$remove_outliers) {
# Simple IQR filtering on both variables
q1_h <- quantile(data$HoursStudied, 0.25, na.rm = TRUE)
q3_h <- quantile(data$HoursStudied, 0.75, na.rm = TRUE)
iqr_h <- q3_h - q1_h
q1_s <- quantile(data$ExamScore, 0.25, na.rm = TRUE)
q3_s <- quantile(data$ExamScore, 0.75, na.rm = TRUE)
iqr_s <- q3_s - q1_s
data <- data %>%
filter(
HoursStudied >= q1_h - 1.5 * iqr_h,
HoursStudied <= q3_h + 1.5 * iqr_h,
ExamScore >= q1_s - 1.5 * iqr_s,
ExamScore <= q3_s + 1.5 * iqr_s
)
}
data
})
model_info <- reactive({
data <- filtered_data()
req(nrow(data) > 1)
fit <- lm(ExamScore ~ HoursStudied, data = data)
slope <- coef(fit)[2]
intercept <- coef(fit)[1]
corr <- cor(data$HoursStudied, data$ExamScore, use = "complete.obs")
r2 <- summary(fit)$r.squared
list(
fit = fit,
slope = slope,
intercept = intercept,
corr = corr,
r2 = r2
)
})
output$scatter_plot <- renderPlotly({
data <- filtered_data()
req(nrow(data) > 1)
info <- model_info()
fit <- info$fit
# line data
x_seq <- seq(
min(data$HoursStudied, na.rm = TRUE),
max(data$HoursStudied, na.rm = TRUE),
length.out = 200
)
line_df <- data.frame(
HoursStudied = x_seq,
ExamScore = predict(fit, newdata = data.frame(HoursStudied = x_seq))
)
line_hover <- paste0(
"Trend line",
"<br>Slope: ", round(info$slope, 3),
"<br>Intercept: ", round(info$intercept, 3),
"<br>Correlation (r): ", round(info$corr, 3),
"<br>R²: ", round(info$r2, 3)
)
p <- plot_ly()
p <- p %>%
add_markers(
data = data,
x = ~HoursStudied,
y = ~ExamScore,
color = ~Attendance,
colors = c("yellow", "green"),
marker = list(size = 8, opacity = 0.75),
key = ~paste(row_number()),
customdata = ~paste(
"Hours Studied:", HoursStudied,
"<br>Attendance:", Attendance,
"<br>Exam Score:", ExamScore
),
hovertemplate = paste(
"Hours Studied: %{x}",
"<br>Exam Score: %{y}",
"<br>Attendance: %{marker.color}",
"<extra></extra>"
),
source = "A"
)
p <- p %>%
add_lines(
data = line_df,
x = ~HoursStudied,
y = ~ExamScore,
line = list(width = 3, color = "black"),
text = line_hover,
hoverinfo = "text",
inherit = FALSE,
name = "Trend line"
)
p %>%
layout(
title = "Exam Score vs Hours Studied",
xaxis = list(title = "Hours Studied"),
yaxis = list(title = "Exam Score"),
dragmode = "zoom"
) %>%
config(
displayModeBar = TRUE,
scrollZoom = TRUE
)
})
output$point_info <- renderText({
click_data <- event_data("plotly_click", source = "A")
if (is.null(click_data)) {
return("Click on a point to see Hours Studied, Attendance, and Exam Score.")
}
data <- filtered_data()
# Find closest row to clicked point
idx <- which.min((data$HoursStudied - click_data$x)^2 + (data$ExamScore - click_data$y)^2)
row <- data[idx, ]
paste0(
"Hours Studied: ", row$HoursStudied, "\n",
"Attendance: ", row$Attendance, "\n",
"Exam Score: ", row$ExamScore
)
})
}
shinyApp(ui, server)
